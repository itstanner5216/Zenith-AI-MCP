    {
      "name": "stashRestore",
      "title": "Stash Restore",
      "description": "Retry failed edits/writes or browse cached stash entries. For symbol version restore/history, use refactor_batch instead.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "apply",
              "restore",
              "list",
              "read"
            ],
            "description": "apply: retry a stashed edit/write. restore: clear a stash entry. list: browse stash. read: inspect a stash entry."
          },
          "stashId": {
            "description": "Stash entry ID for apply/read/restore.",
            "type": "number"
          },
          "corrections": {
            "description": "apply: disambiguation hints for ambiguous edits.",
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "index": {
                  "type": "number",
                  "description": "1-based edit index."
                },
                "startLine": {
                  "description": "Exact line for block edits.",
                  "type": "number"
                },
                "nearLine": {
                  "description": "Approximate line for symbol edits.",
                  "type": "number"
                }
              },
              "required": [
                "index"
              ]
            }
          },
          "newPath": {
            "description": "apply: redirect write to a different path.",
            "type": "string"
          },
          "dryRun": {
            "default": false,
            "description": "apply: preview the result without writing.",
            "type": "boolean"
          },
          "file": {
            "description": "list/read/restore: filter by file path.",
            "type": "string"
          },
          "type": {
            "description": "list: filter entries by type.",
            "type": "string",
            "enum": [
              "edit",
              "write"
            ]
          }
        },
        "required": [
          "mode"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": true,
        "idempotentHint": false
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    },
    {
      "name": "refactor_batch",
      "title": "Refactor Batch",
      "description": "Apply one edit pattern across multiple similar symbols, with rollback. Core pipeline: loadDiff (symbol bodies + context) → apply (write edits). query is optional — you can skip it and call loadDiff directly with explicit {symbol, file} pairs if you already know the targets (e.g. from search_files). After a successful apply: reapply sends the same cached edit to new targets, restore rolls back any symbol to a prior snapshot. Every apply/reapply/restore snapshots pre-edit text automatically. No default mode — mode is always required.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "query",
              "loadDiff",
              "apply",
              "reapply",
              "restore",
              "history"
            ],
            "description": "Required. query: impact analysis — who calls/is called by a symbol. loadDiff: load symbol bodies with surrounding context into a diff you edit and send back. apply: write the edited diff. reapply: apply a previously successful edit pattern to new targets. restore: rollback a symbol to a snapshotted version. history: list available version snapshots for a symbol."
          },
          "target": {
            "description": "query: The symbol name to analyze for impact. Returns numbered list of callers (forward) or callees (reverse) grouped by file. Optional step — you can skip query entirely and go straight to loadDiff with explicit {symbol, file} pairs.",
            "type": "string"
          },
          "fileScope": {
            "description": "query: Repo-relative file path. Required when target has definitions in multiple files — the server will list them and ask you to pick.",
            "type": "string"
          },
          "direction": {
            "default": "forward",
            "description": "query: forward = which symbols call target (blast radius). reverse = what does target call (dependencies).",
            "type": "string",
            "enum": [
              "forward",
              "reverse"
            ]
          },
          "depth": {
            "default": 1,
            "description": "query: How many hops to traverse the call graph. 1 = direct callers/callees only.",
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "selection": {
            "description": "loadDiff: Which symbols to load. Either numeric indices from a prior query result, or explicit {symbol, file?} pairs. You can skip query and go straight to loadDiff with explicit pairs.",
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 9007199254740991
                },
                {
                  "type": "object",
                  "properties": {
                    "symbol": {
                      "type": "string"
                    },
                    "file": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "symbol"
                  ]
                }
              ]
            }
          },
          "contextLines": {
            "default": 5,
            "description": "loadDiff: How many lines above and below each symbol body to include as read-only context. Context lines are marked with │ so you can distinguish them from the editable body.",
            "type": "integer",
            "minimum": 0,
            "maximum": 30
          },
          "loadMore": {
            "default": false,
            "description": "loadDiff: When a prior loadDiff was truncated at the char budget, call loadDiff again with loadMore=true to get the next page.",
            "type": "boolean"
          },
          "payload": {
            "description": "apply: The edited diff you're sending back. Format: one or more groups, each starting with a header line 'symbolName idx1,idx2 [ack:N]' followed by the new function body on subsequent lines. Example: 'validateCard 1,2,3 ack:3\\nfunction validateCard(card) { ... }'. Indices match the [N] tags from loadDiff output.",
            "type": "string"
          },
          "dryRun": {
            "default": false,
            "description": "apply/reapply/restore: Validate everything (syntax gate, outlier checks, char budget) without writing any files. Returns what would happen.",
            "type": "boolean"
          },
          "symbolGroup": {
            "description": "reapply: The symbol name from a prior successful apply. The server caches the edit body and reuses it on newTargets.",
            "type": "string"
          },
          "newTargets": {
            "description": "reapply: Symbols to apply the cached edit pattern to. Same format as loadDiff selection — names or {symbol, file?} pairs.",
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "properties": {
                    "symbol": {
                      "type": "string"
                    },
                    "file": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "symbol"
                  ]
                }
              ]
            }
          },
          "ack": {
            "description": "reapply: When the server flags structurally different targets as outliers, provide their indices here to acknowledge and proceed anyway.",
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            }
          },
          "symbol": {
            "description": "restore/history: The symbol name. restore rolls it back to a prior snapshot; history lists available snapshots.",
            "type": "string"
          },
          "file": {
            "description": "restore/history: File containing the symbol. Required for restore, optional filter for history.",
            "type": "string"
          },
          "version": {
            "description": "restore: Which version index to restore (from history output). Omit to list available versions instead of restoring.",
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "mode"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": true,
        "idempotentHint": false
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    }
  ]
}