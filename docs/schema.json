{
  "tools": [
    {
      "name": "read_file",
      "title": "Read File",
      "description": "Read file content.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "File path."
          },
          "maxChars": {
            "description": "Max chars. Up to 400K.",
            "type": "number"
          },
          "head": {
            "description": "First N lines.",
            "type": "number"
          },
          "tail": {
            "description": "Last N lines.",
            "type": "number"
          },
          "offset": {
            "description": "Start line (0-based). Use with head.",
            "type": "number"
          },
          "showLineNumbers": {
            "description": "Prefix lines with numbers.",
            "type": "boolean"
          },
          "compression": {
            "description": "Compress whitespace.",
            "type": "boolean"
          },
          "aroundLine": {
            "description": "Center window on this line.",
            "type": "number"
          },
          "context": {
            "description": "Window radius. Default 30.",
            "type": "number"
          },
          "ranges": {
            "description": "Explicit line ranges.",
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "startLine": {
                  "type": "number"
                },
                "endLine": {
                  "type": "number"
                }
              },
              "required": [
                "startLine",
                "endLine"
              ]
            }
          }
        },
        "required": [
          "path"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "annotations": {
        "readOnlyHint": true
      },
      "execution": {
        "taskSupport": "forbidden"
